{
  "manifest_version": 3,
  "name": "Rainio Tab",
  "version": "1.0.0",
  "description": "A beautiful new tab page with search functionality",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ]
}